class Solution {
    public int firstUniqChar(String s) {
        // create freq array to keep in mind the number of time the character has been repeated
                int[] freq = new int[26];

        // to count the number of times the letter occurred
        for (int i = 0; i < s.length(); i++) {
            freq[s.charAt(i) - 'a']++;}
        // to find first letter whose frequency is 1
        for (int i = 0; i < s.length(); i++) {
            if (freq[s.charAt(i) - 'a'] == 1) {
                return i;
            }
}
        return -1;
    }
}
