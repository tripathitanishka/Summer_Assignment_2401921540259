class Solution {
    public String longestPalindrome(String s) {
        // Edge case
        if (s == null || s.length() < 2) {
            return s;}
        // Stores starting index of answer
        int start = 0;
        // Stores length of longest palindrome
        int maxLen = 1;
        // Try every index as centre
        for (int i = 0; i < s.length(); i++) {
            // Odd length palindrome
            int len1 = expand(s, i, i);
            // Even length palindrome
            int len2 = expand(s, i, i + 1);
            // Choose bigger one
            int len = Math.max(len1, len2);
            // Update answer if longer palindrome found
            if (len > maxLen) {
                maxLen = len;
                start = i - (len - 1) / 2;}}
        return s.substring(start, start + maxLen);}
    // Expands from centre and returns palindrome length
    private int expand(String s, int left, int right) {
        // Expand while characters are equal
        while (left >= 0
                && right < s.length() && s.charAt(left) == s.charAt(right)) {
            left--;
            right++;
        }
        // We expand one step too far,so actual length is:
        return right - left - 1;
    }
}
