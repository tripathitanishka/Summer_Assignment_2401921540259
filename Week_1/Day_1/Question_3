//Week_1_Day1_Question_3
//Best Time to Buy and Sell Stocks

class Solution {
    public int maxProfit(int[] prices) {
        int prof = 0;
        int min = Integer.MAX_VALUE;
        for (int i = 0 ; i < prices.length ; i++){
                if (prices[i] < min){
                    min = prices[i];
                }
                else{
                    prof = Math.max(prof, prices[i]-min );
                }
        }
        return prof;
    }
}
