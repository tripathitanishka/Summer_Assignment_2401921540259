//Week_1_Day1_Question_1
//Two Sum Solution

class Solution {
    public int[] twoSum(int[] nums, int target) {
        HashMap<Integer,Integer> map = new HashMap<>();
        {
            for (int i = 0 ; i < nums.length ; i++){
                int secndno = target - nums [i];
                if ( map.containsKey(secndno))
                    return new int [] {map.get(secndno),i};
            map.put(nums[i],i);
        }
        return new int [] {-1,-1};
    }}
}
