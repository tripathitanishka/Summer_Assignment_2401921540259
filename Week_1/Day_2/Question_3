//Week_1 Day_2 Question 3
//Maximum Average Subarray I

 class Solution {
    public double findMaxAverage(int[] nums, int k) {
        double max = Double.NEGATIVE_INFINITY;
        for ( int i = 0 ; i <= nums.length-k ; i++){
            double sum = 0 ;
            for ( int j = i ; j < i + k ; j++){
                sum = sum + ( double ) nums[j];
            }
            max = Math.max (max,sum/k);
        }
        return max;
    }
}
